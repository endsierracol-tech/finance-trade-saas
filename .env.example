# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_TU_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # NUNCA exponer al cliente

# ─── PRISMA / BASE DE DATOS ───────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL → Transaction Pooler (puerto 6543) — para Vercel/serverless
DATABASE_URL=postgresql://postgres.TU_PROJECT_ID:TU_PASSWORD@aws-0-TU_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL → Conexión directa (puerto 5432) — solo para migraciones locales
DIRECT_URL=postgresql://postgres:TU_PASSWORD@db.TU_PROJECT_ID.supabase.co:5432/postgres
